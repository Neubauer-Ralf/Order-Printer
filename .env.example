# KuraKura Order Printer Configuration
# Copy this file to .env and fill in your values.

# iCloud credentials
# Use your @icloud.com address, even if you use a custom domain
ICLOUD_EMAIL=your-email@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# IMAP settings (defaults work for iCloud)
# IMAP_SERVER=imap.mail.me.com
# IMAP_PORT=993

# Printer name (find yours with: lpstat -p)
PRINTER_NAME=your-printer-name

# Printer character width (32 for 58mm, 48 for 80mm)
# PRINT_WIDTH=32

# How often to check for new emails (seconds)
# CHECK_INTERVAL=120

# Email matching filters
# SENDER_FILTER=squarespace
# SUBJECT_FILTER=kura kura

# Log file location
# LOG_FILE=/home/pi/kurakura-orders.log
